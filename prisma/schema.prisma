generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
  url       = env("DATABASE_URL")
}

model Preventive {
  id    Int          @id @default(autoincrement())
  meals DailyMeals[]
}

enum Day {
  first
  default
  last
}

enum Type {
  lunch
  dinner
}

model Meal {
  id          Int          @id @default(autoincrement())
  name        String
  day         Day
  type        Type
  description String       @default("")
  cost        Int          @default(0)
  assignments DailyMeals[]

  @@unique([name, day, type])
}

model DailyMeals {
  id           Int        @id @default(autoincrement())
  date         DateTime
  preventive   Preventive @relation(fields: [preventiveId], references: [id])
  preventiveId Int
  meal         Meal       @relation(fields: [mealId], references: [id])
  mealId       Int

  @@unique([preventiveId, mealId, date])
}

model Service {
  id            Int             @id @default(autoincrement())
  name          String
  category      ServiceCategory @relation(fields: [categoryId], references: [id])
  categoryId    Int
  costPerPerson Int             @default(0)
  groupCost     Int             @default(0)
  isRequiredVan Boolean         @default(false)
  description   String          @default("")
  vanCost       Int             @default(0)

  @@unique([name, categoryId])
}

model ServiceCategory {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  services Service[]
}
