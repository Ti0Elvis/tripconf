generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
  url       = env("DATABASE_URL")
}

model Preventive {
  id Int @id @default(autoincrement())   
}

model Meal {
  id Int @id @default(autoincrement())   
}

model Service {
  id Int @id @default(autoincrement())   
}

model ServiceCategory {
  id Int @id @default(autoincrement())   
}